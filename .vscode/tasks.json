{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "uv sync",
      "type": "shell",
      "command": "uv sync --extra dev"
    },
    {
      "label": "import fixture",
      "type": "shell",
      "command": "uv run python -m status_bridge.cli import-fixture"
    },
    {
      "label": "run api",
      "type": "shell",
      "command": "uv run uvicorn status_bridge.app:app --reload"
    },
    {
      "label": "pytest",
      "type": "shell",
      "command": "uv run pytest"
    },
    {
      "label": "ruff",
      "type": "shell",
      "command": "uv run ruff check ."
    }
  ]
}
